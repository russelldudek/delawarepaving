@import url("brand-tokens.css");
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;background:var(--aggregate-075);color:var(--ink);font-family:"Noto Sans",Roboto,"Liberation Sans",Arial,sans-serif;line-height:1.55;-webkit-font-smoothing:antialiased}a{color:inherit}img{max-width:100%;display:block}button{font:inherit}.skip-link{position:absolute;left:-999px;top:0}.skip-link:focus{left:12px;top:12px;z-index:999;padding:10px 14px;background:#fff;color:#000;border:3px solid var(--dvp-blue)}
.site-nav{position:sticky;top:0;z-index:40;background:rgba(16,19,24,.94);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,.11)}.nav-inner{max-width:1220px;margin:auto;min-height:74px;padding:10px 24px;display:flex;align-items:center;gap:24px}.nav-logo{width:126px;min-width:126px}.nav-kicker{font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:#cfd4d9}.nav-links{margin-left:auto;display:flex;gap:20px;align-items:center}.nav-links a{color:#fff;text-decoration:none;font-size:.88rem;font-weight:700}.nav-links a:hover,.nav-links a:focus{color:var(--dvp-blue)}.nav-cta{border:1px solid var(--dvp-red);padding:9px 14px;border-radius:999px}
.hero{position:relative;overflow:hidden;background:linear-gradient(115deg,rgba(16,19,24,.98) 0%,rgba(16,19,24,.93) 50%,rgba(16,19,24,.70) 100%),url('assets/brand/dvp-truck.jpg') center 42%/cover;min-height:760px;color:#fff}.hero::after{content:"";position:absolute;inset:auto 0 0;height:16px;background:repeating-linear-gradient(90deg,var(--dvp-red) 0 48px,transparent 48px 64px,var(--dvp-blue) 64px 112px,transparent 112px 128px)}.hero-grid{position:relative;z-index:2;max-width:1220px;margin:auto;padding:74px 24px 86px;display:grid;grid-template-columns:minmax(0,1.02fr) minmax(460px,.98fr);gap:56px;align-items:center}.employer-lockup{display:flex;align-items:center;gap:18px;margin-bottom:30px}.employer-lockup img{width:190px}.employer-lockup-text{border-left:1px solid rgba(255,255,255,.35);padding-left:18px}.eyebrow{margin:0 0 8px;color:var(--dvp-blue);font-size:.76rem;letter-spacing:.18em;text-transform:uppercase;font-weight:800}.employer-lockup-text strong{display:block;font-size:.84rem}.employer-lockup-text span{display:block;color:#cbd0d5;font-size:.8rem}.hero h1,.display{font-family:"Noto Sans Display","Roboto Condensed","Arial Narrow",sans-serif;font-stretch:condensed;letter-spacing:-.045em;line-height:.92}.hero h1{font-size:clamp(4.4rem,8.2vw,7.8rem);margin:0 0 24px;max-width:760px}.hero h1 span{color:var(--dvp-red)}.hero-lede{font-size:1.18rem;max-width:650px;color:#e5e8eb;margin:0 0 28px}.hero-actions,.doc-actions{display:flex;gap:12px;flex-wrap:wrap}.button{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:5px;padding:13px 18px;text-decoration:none;font-weight:800;border:1px solid transparent}.button.primary{background:var(--dvp-red);color:#fff}.button.secondary{border-color:rgba(255,255,255,.45);color:#fff;background:rgba(255,255,255,.06)}.button.light{background:#fff;color:var(--asphalt-950);border-color:#d4d8dc}.button.dark{background:var(--asphalt-950);color:#fff}.button:hover,.button:focus{transform:translateY(-2px)}.location-note{margin-top:24px;color:#cdd2d7;font-size:.88rem}.location-note b{color:#fff}
.load-rig{background:rgba(13,16,20,.86);border:1px solid rgba(255,255,255,.18);border-radius:18px;padding:18px;box-shadow:0 30px 90px rgba(0,0,0,.32)}.rig-header{display:flex;justify-content:space-between;align-items:start;gap:12px;padding:5px 6px 14px}.rig-title{font-weight:900}.rig-status{font-size:.72rem;color:var(--signal-amber);text-transform:uppercase;letter-spacing:.12em}.road-window{position:relative;height:405px;border-radius:11px;overflow:hidden;background:#d9eef6;border:1px solid rgba(255,255,255,.16)}.sky-label{position:absolute;top:10px;left:14px;color:#16475b;font-size:.68rem;text-transform:uppercase;letter-spacing:.13em;font-weight:800}.road-surface{position:absolute;top:76px;left:0;right:0;height:34px;background:#1c2127;border-top:4px solid #4a5159}.lane-line{position:absolute;top:91px;left:-20%;width:140%;height:5px;background:repeating-linear-gradient(90deg,transparent 0 42px,#fff 42px 86px,transparent 86px 128px);opacity:.75}.roller{position:absolute;z-index:5;top:26px;left:4%;width:110px;height:66px;animation:compact-pass 8s ease-in-out infinite}.roller-body{position:absolute;left:25px;top:0;width:64px;height:33px;background:var(--dvp-red);border-radius:8px 10px 3px 3px}.roller-cab{position:absolute;left:36px;top:-18px;width:33px;height:24px;background:var(--dvp-blue);clip-path:polygon(12% 100%,26% 0,100% 0,100% 100%)}.roller-drum{position:absolute;left:2px;top:30px;width:45px;height:34px;border-radius:50%;background:#69737d;border:5px solid #2e343b}.roller-wheel{position:absolute;righ