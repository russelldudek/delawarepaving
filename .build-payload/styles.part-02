tack-head{padding:24px 26px;border-bottom:1px solid rgba(255,255,255,.13);display:flex;justify-content:space-between;gap:20px}.stack-head h3{margin:0;font-size:1.15rem}.stack-head span{font-size:.76rem;color:#b7c0c8}.stack-layer{position:relative;display:grid;grid-template-columns:52px 1fr auto;gap:16px;align-items:center;padding:22px 26px;border-bottom:1px solid rgba(255,255,255,.1);transition:background .3s,transform .3s}.stack-layer::before{content:attr(data-index);width:36px;height:36px;border-radius:50%;display:grid;place-items:center;background:rgba(255,255,255,.08);font-weight:900;color:var(--dvp-blue)}.stack-layer h4{margin:0 0 5px;font-size:1rem}.stack-layer p{margin:0;color:#bfc6cc;font-size:.82rem}.stack-layer .layer-decision{font-size:.72rem;font-weight:900;text-transform:uppercase;letter-spacing:.08em;color:#9fa9b1}.stack-layer.active{background:linear-gradient(90deg,rgba(237,28,36,.23),rgba(0,175,239,.12));transform:translateX(5px)}.stack-layer.active .layer-decision{color:var(--signal-amber)}.scenario-panel{background:#fff;border-radius:18px;padding:25px;box-shadow:var(--shadow)}.scenario-panel h3{margin:0 0 10px;font-size:1.2rem}.scenario-panel .scenario-problem{color:var(--muted);font-size:.9rem;min-height:76px}.scenario-route{border-top:1px solid #e2e5e8;padding-top:16px;margin-top:16px}.scenario-route strong{display:block;color:var(--dvp-red);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;margin-bottom:5px}.scenario-route p{margin:0;font-weight:800}.scenario-metrics{margin:18px 0 0;padding:0;list-style:none}.scenario-metrics li{padding:9px 0;border-bottom:1px solid #e8eaec;font-size:.82rem}.scenario-metrics li::before{content:"+";color:var(--dvp-blue);font-weight:900;margin-right:8px}
.scorecard{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#cad0d5;border:1px solid #cad0d5}.metric{background:#fff;padding:24px;min-height:190px}.metric .metric-no{color:var(--dvp-blue);font-weight:900;font-size:.75rem}.metric h3{font-family:"Noto Sans Display",sans-serif;margin:8px 0;font-size:1.45rem}.metric p{color:var(--muted);font-size:.84rem}.metric .measure{display:block;margin-top:16px;padding-top:12px;border-top:3px solid var(--asphalt-950);font-size:.76rem;font-weight:800}
.evidence-road{position:relative;display:grid;grid-template-columns:1fr 1fr;gap:30px 60px}.evidence-road::before{content:"";position:absolute;left:50%;top:0;bottom:0;width:6px;background:repeating-linear-gradient(to bottom,var(--aggregate-300) 0 26px,transparent 26px 44px);transform:translateX(-50%)}.evidence-item{background:#fff;color:var(--ink);border-radius:12px;padding:24px;position:relative}.evidence-item::after{content:"";position:absolute;top:30px;width:24px;height:5px;background:var(--dvp-red)}.evidence-item:nth-child(odd)::after{right:-24px}.evidence-item:nth-child(even)::after{left:-24px}.evidence-item:nth-child(even){margin-top:68px}.evidence-item h3{margin:0 0 8px}.evidence-item p{margin:0;color:var(--muted);font-size:.86rem}.evidence-item .proof-tag{color:var(--dvp-red);font-size:.7rem;text-transform:uppercase;letter-spacing:.12em;font-weight:900;margin-bottom:7px}
.timeline{display:grid;grid-template-columns:repeat(4,1fr);border-top:7px solid var(--asphalt-950)}.phase{padding:26px 20px 10px;border-right:1px solid #cdd2d6;position:relative}.phase::before{content:"";position:absolute;top:-15px;left:20px;width:22px;height:22px;border-radius:50%;background:var(--dvp-red);border:5px solid #fff}.phase .days{font-size:.74rem;text-transform:uppercase;letter-spacing:.13em;font-weight:900;color:var(--dvp-blue)}.phase h3{font-family:"Noto Sans Display",sans-serif;font-size:1.45rem;margin:10px 0}.phase ul{padding-left:18px;font-size:.82rem;color:var(--muted)}
.objection{display:grid;grid-template-columns:.8fr 1.2fr;gap:48px;align-items:center}.objection-q{font-family:"Noto Sans Display",sans-serif;font-size:clamp(2.2rem,4vw,4rem);font-weight:900;line-height:1.02}.objection-a{border-left:5px solid var(--dvp-blue);padding-left:26px}.objection-a p{color:rgba(255,255,255,.78)}.objection-a strong{color:#fff}
.question-roadmap{counter-reset:q;display:grid;grid-template-columns:1fr 1fr;gap:16px}.exec-question{counter-increment:q;background:#fff;border-left:7px solid var(--dvp-red);padding:20px 22px;font-weight:800}.exec-question::before{content:"0" counter(q);display:block;color:var(--dvp-blue);font-size:.72rem;letter-spacing:.15em;margin-bottom:8px}.final-cta{display:grid;grid-template-columns:1fr auto;gap:30px;align-items:center}.final-cta h2{margin:0;color:#fff}.footer{background:#090b0e;color:#b6bdc4;padding:30px 24px;font-size:.76rem}.footer-inner{max-width:1160px;margin:auto;display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap}.footer a{color:#fff}
/* Document system */
.document-bo