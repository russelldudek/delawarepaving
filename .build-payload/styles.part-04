ed);font-weight:900}.plan-lane h3{margin:0 0 3px}.load-test{border:1px solid #cbd1d5;margin-top:10px}.load-row{display:grid;grid-template-columns:1.05in 1fr 1.15in;gap:10px;padding:8px 10px;border-bottom:1px solid #d6dadd;align-items:center}.load-row:last-child{border-bottom:0}.load-row strong{font-size:8pt}.load-row span{font-size:7.3pt}.rating{display:flex;gap:4px;justify-content:flex-end}.rating i{display:block;width:11px;height:11px;border:1px solid #66717b}.rating i.on{background:var(--dvp-red);border-color:var(--dvp-red)}.verdict{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-top:11px}.verdict div{padding:10px;color:#fff}.verdict strong{display:block;font-size:8pt}.verdict span{font-size:6.8pt}.verdict .go{background:#23724b}.verdict .stabilize{background:#b56c09}.verdict .observe{background:#4b5864}
.method-band{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:10px}.method-step{border-top:4px solid var(--dvp-red);background:#f0f3f5;padding:8px 9px;min-height:61px}.method-step b{display:block;font-size:7.5pt;margin-bottom:3px}.method-step span{display:block;font-size:6.7pt;line-height:1.35;color:#53606a}.mechanism-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-top:8px}.mechanism-item{border:1px solid #cfd4d8;border-top:5px solid var(--dvp-blue);padding:10px 11px;min-height:115px}.mechanism-item h3{font-size:8.3pt;margin:0 0 5px}.mechanism-item p{font-size:7.15pt;line-height:1.42;margin:0;color:#4e5963}.role-fit-band{margin-top:10px;background:var(--asphalt-950);color:#fff;padding:12px 14px;border-left:7px solid var(--dvp-red)}.role-fit-band h3{font-size:8.5pt;margin:0 0 6px;text-transform:uppercase;letter-spacing:.08em}.role-fit-band p{font-size:7.25pt;line-height:1.45;margin:0;color:#e3e6e8}
@keyframes compact-pass{0%,10%{transform:translateX(0)}45%,55%{transform:translateX(300px)}90%,100%{transform:translateX(0)}}@keyframes danger-pulse{0%,100%{box-shadow:0 0 0 5px rgba(237,28,36,.12)}50%{box-shadow:0 0 0 11px rgba(237,28,36,.25)}}@keyframes void-breathe{0%,100%{transform:scale(1);opacity:.72}50%{transform:scale(.45);opacity:.28}}
@media(max-width:960px){.nav-kicker{display:none}.nav-links{gap:12px;overflow-x:auto}.hero-grid{grid-template-columns:1fr;padding-top:54px}.hero{min-height:auto}.load-rig{max-width:620px}.mandate-grid,.system-shell,.objection{grid-template-columns:1fr}.scorecard{grid-template-columns:1fr 1fr}.timeline{grid-template-columns:1fr 1fr;gap:24px 0}.phase:nth-child(2){border-right:0}.evidence-road{grid-template-columns:1fr}.evidence-road::before{left:20px}.evidence-item,.evidence-item:nth-child(even){margin:0 0 0 45px}.evidence-item::after,.evidence-item:nth-child(even)::after{left:-24px;right:auto}.final-cta{grid-template-columns:1fr}.print-sheet{width:min(8.5in,calc(100vw - 28px));min-height:auto}.sheet-inner{padding:24px}.page-footer{position:static;margin-top:18px}.document-header{grid-template-columns:1fr 150px}.doc-grid-2,.report-grid{grid-template-columns:1fr}}
@media(max-width:640px){.nav-inner{padding:8px 14px}.nav-logo{width:92px;min-width:92px}.nav-links a:not(.nav-cta){display:none}.hero-grid{padding:38px 16px 70px;gap:32px}.employer-lockup{align-items:flex-start}.employer-lockup img{width:130px}.hero h1{font-size:3.65rem}.hero-lede{font-size:1rem}.road-window{height:355px}.layer{grid-template-columns:104px 1fr 24px;padding:0 9px}.layer-1{top:110px;height:42px}.layer-2{top:152px;height:47px}.layer-3{top:199px;height:50px}.layer-4{top:249px;height:52px}.layer-5{top:301px;height:54px}.roller{transform:scale(.8);transform-origin:left bottom}.scenario-buttons{display:grid;grid-template-columns:1fr}.section{padding:66px 16px}.section h2{font-size:2.8rem}.tension{grid-template-columns:1fr 40px 1fr;padding:15px}.tension-side{font-size:1.05rem}.scorecard{grid-template-columns:1fr}.question-roadmap{grid-template-columns:1fr}.timeline{grid-template-columns:1fr}.phase{border-right:0}.document-toolbar{padding:10px}.toolbar-inner{align-items:flex-start;flex-direction:column}.document-wrap{padding:12px 0 40px}.print-sheet{width:100%;margin-bottom:12px;box-shadow:none}.sheet-inner{padding:18px 15px}.document-header{grid-template-columns:1fr;gap:10px}.doc-logo-box{width:160px}.candidate-name{font-size:23pt}.contact-line{font-size:7.4pt}.capability-strip{grid-template-columns:1fr 1fr}.experience-head{grid-template-columns:1fr}.resume-page2-header{align-items:flex-start;flex-direction:column}.resume-page2-header span{text-align:left}.report-header{grid-template-columns:1fr}.report-header .doc-logo-box{width:150px}.load-row{grid-template-columns:1fr}.rating{justify-content:flex-start}.verdict{grid-template-columns:1fr}}
