n-iteration-count:1!important;transition-duration:.001ms!important}.roller{left:55%}.void{transform:scale(.45);opacity:.35}}
@media print{@page{size:Letter;margin:0}html,body{background:#fff!important;print-color-adjust:exact;-webkit-print-color-adjust:exact}.site-nav,.document-toolbar,.web-only,.footer{display:none!important}.document-wrap{padding:0}.print-sheet{width:8.5in!important;height:11in!important;min-height:11in!important;margin:0!important;box-shadow:none!important;overflow:hidden!important;break-after:page;page-break-after:always}.print-sheet:last-child{break-after:auto;page-break-after:auto}.sheet-inner{padding:.46in .5in .48in!important;height:100%;position:relative}.page-footer{position:absolute!important;left:.5in!important;right:.5in!important;bottom:.2in!important;margin:0!important}.document-header{grid-template-columns:1fr 1.85in!important}.report-header{grid-template-columns:1fr 1.65in!important}.doc-grid-2,.report-grid{grid-template-columns:1fr 1fr!important}.capability-strip{grid-template-columns:repeat(3,1fr)!important}.load-row{grid-template-columns:1.05in 1fr 1.15in!important}.method-band{grid-template-columns:repeat(4,1fr)!important}.mechanism-grid{grid-template-columns:repeat(3,1fr)!important}.verdict{grid-template-columns:repeat(3,1fr)!important}.print-only{display:block!important}}
