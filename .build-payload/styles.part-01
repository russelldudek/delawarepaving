t:2px;top:35px;width:29px;height:29px;border-radius:50%;background:#20252b;border:5px solid #6e7882}.layer{position:absolute;left:0;right:0;display:grid;grid-template-columns:136px 1fr 34px;align-items:center;padding:0 14px;color:#fff;font-size:.75rem;font-weight:800;transition:filter .35s,opacity .35s}.layer em{font-style:normal;font-weight:500;opacity:.85;font-size:.68rem}.layer .health{width:12px;height:12px;border-radius:50%;justify-self:end;background:#6f7a84;box-shadow:0 0 0 5px rgba(255,255,255,.09)}.layer[data-state="ready"] .health{background:#47d17c}.layer[data-state="risk"] .health{background:var(--signal-amber)}.layer[data-state="void"] .health{background:var(--dvp-red);animation:danger-pulse 1.6s ease-in-out infinite}.layer-1{top:110px;height:52px;background:#30373f}.layer-2{top:162px;height:56px;background:#3e4852}.layer-3{top:218px;height:59px;background:#56626d}.layer-4{top:277px;height:62px;background:#687786}.layer-5{top:339px;height:66px;background:#715849}.aggregate{position:absolute;inset:0;opacity:.18;background-image:radial-gradient(circle at 12% 30%,#fff 0 2px,transparent 3px),radial-gradient(circle at 67% 62%,#fff 0 1.5px,transparent 2.5px),radial-gradient(circle at 88% 18%,#fff 0 1px,transparent 2px);background-size:44px 38px}.void{position:absolute;width:16px;height:9px;border-radius:50%;background:#111;opacity:.72;animation:void-breathe 2.2s ease-in-out infinite}.void.v1{left:42%;top:130px}.void.v2{left:73%;top:188px;animation-delay:.4s}.void.v3{left:58%;top:247px;animation-delay:.8s}.void.v4{left:81%;top:309px;animation-delay:1.2s}.rig-readout{padding:14px 8px 4px;display:grid;grid-template-columns:1fr auto;gap:12px;align-items:end}.rig-readout strong{display:block;font-size:.92rem}.rig-readout span{color:#bac1c8;font-size:.76rem}.load-score{font-family:"Noto Sans Display",sans-serif;font-size:2.15rem;font-weight:900;color:var(--signal-amber);line-height:1}.scenario-buttons{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}.scenario-buttons button{border:1px solid rgba(255,255,255,.18);background:#232931;color:#dce1e5;border-radius:999px;padding:8px 11px;font-size:.72rem;font-weight:800;cursor:pointer}.scenario-buttons button[aria-pressed="true"]{background:var(--dvp-blue);color:#081117;border-color:var(--dvp-blue)}
.section{padding:92px 24px}.section.dark{background:var(--asphalt-950);color:#fff}.section.red{background:var(--dvp-red);color:#fff}.section.blueprint{background-color:#edf8fc;background-image:linear-gradient(rgba(0,175,239,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(0,175,239,.08) 1px,transparent 1px);background-size:34px 34px}.section-inner{max-width:1160px;margin:auto}.section-intro{max-width:800px;margin-bottom:52px}.section-label{display:flex;align-items:center;gap:12px;text-transform:uppercase;letter-spacing:.16em;font-size:.75rem;font-weight:900;color:var(--dvp-red)}.dark .section-label,.red .section-label{color:var(--dvp-blue)}.section-label::before{content:"";width:44px;height:4px;background:currentColor}.section h2{font-family:"Noto Sans Display","Roboto Condensed",sans-serif;font-size:clamp(2.8rem,5vw,5rem);letter-spacing:-.04em;line-height:.98;margin:14px 0 20px}.section-intro p{font-size:1.1rem;color:var(--muted)}.dark .section-intro p,.red .section-intro p{color:rgba(255,255,255,.78)}
.mandate-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:44px;align-items:start}.mandate-statement{font-family:"Noto Sans Display",sans-serif;font-size:clamp(2rem,4vw,3.5rem);line-height:1.08;letter-spacing:-.035em;font-weight:800}.mandate-statement em{font-style:normal;color:var(--dvp-red)}.pressure-rail{border-left:5px solid var(--asphalt-950)}.pressure{padding:20px 24px;border-bottom:1px solid #d9dde1}.pressure b{display:block;font-size:1rem;margin-bottom:6px}.pressure span{color:var(--muted);font-size:.9rem}
.tension-field{display:grid;gap:20px}.tension{display:grid;grid-template-columns:1fr 64px 1fr;align-items:center;background:#fff;color:var(--ink);border-radius:12px;padding:20px;box-shadow:0 12px 35px rgba(0,0,0,.12)}.tension-side{font-family:"Noto Sans Display",sans-serif;font-size:1.45rem;font-weight:800}.tension-side:last-child{text-align:right}.tension-joint{height:4px;background:linear-gradient(90deg,var(--dvp-red),var(--signal-amber),var(--dvp-blue));position:relative}.tension-joint::after{content:"";position:absolute;width:13px;height:13px;border-radius:50%;background:#fff;border:4px solid var(--asphalt-950);left:50%;top:50%;transform:translate(-50%,-50%)}.tension-note{grid-column:1/-1;color:var(--muted);font-size:.83rem;padding-top:10px}
.system-shell{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(310px,.8fr);gap:28px}.layer-stack{background:var(--asphalt-950);color:#fff;border-radius:18px;overflow:hidden;box-shadow:var(--shadow)}.s