dy{background:#dfe3e6}.document-toolbar{position:sticky;top:0;z-index:30;background:#11151a;color:#fff;padding:12px 20px}.toolbar-inner{max-width:930px;margin:auto;display:flex;justify-content:space-between;align-items:center;gap:12px}.toolbar-title{font-size:.82rem;font-weight:800}.doc-actions .button{padding:8px 12px;font-size:.76rem}.document-wrap{padding:28px 14px 70px}.print-sheet{width:8.5in;min-height:11in;margin:0 auto 24px;background:#fff;box-shadow:0 16px 54px rgba(0,0,0,.17);position:relative;overflow:visible}.sheet-inner{padding:.46in .5in .48in}.document-header{display:grid;grid-template-columns:1fr 1.85in;gap:.22in;align-items:center;border-bottom:5px solid var(--dvp-red);padding-bottom:.16in;margin-bottom:.2in}.candidate-name{font-family:"Noto Sans Display",sans-serif;font-size:28pt;letter-spacing:-.04em;line-height:.9;font-weight:900}.candidate-role{font-size:9.4pt;font-weight:800;margin-top:7px;color:#303a43}.contact-line{font-size:6.9pt;line-height:1.5;color:#4e5963;margin-top:7px}.contact-line a{text-decoration:none;color:#2d4b5c}.doc-logo-box{background:var(--asphalt-950);padding:10px 12px;border-radius:4px}.doc-logo-box img{width:100%;height:auto}.doc-kicker{font-size:7pt;letter-spacing:.16em;text-transform:uppercase;color:var(--dvp-blue);font-weight:900}.doc-title{font-family:"Noto Sans Display",sans-serif;font-size:20pt;line-height:1.03;margin:5px 0 8px;letter-spacing:-.025em}.doc-subtitle{font-size:8.5pt;color:#5b6670;margin:0}.doc-section{margin-top:.18in}.doc-section h2{font-family:"Noto Sans Display",sans-serif;font-size:10.7pt;letter-spacing:.08em;text-transform:uppercase;margin:0 0 7px;padding-bottom:4px;border-bottom:2px solid var(--asphalt-950)}.summary{font-size:8.6pt;line-height:1.48;margin:0}.capability-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;margin:.15in 0}.capability{background:#eef7fb;border-left:3px solid var(--dvp-blue);padding:7px 8px;font-size:7pt;font-weight:800;line-height:1.25}.experience{margin-bottom:9px}.experience-head{display:grid;grid-template-columns:1fr auto;align-items:baseline;gap:10px}.experience h3{font-size:9.1pt;margin:0;line-height:1.1}.experience .org{color:var(--dvp-red)}.experience .dates{font-size:7pt;font-weight:800;color:#5d6872}.experience .role-note{font-size:7.2pt;color:#4f5a64;font-style:italic;margin:2px 0 3px}.experience ul{margin:3px 0 0;padding-left:14px}.experience li{font-size:7.45pt;line-height:1.34;margin:1.5px 0}.doc-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:.18in}.sidebar-box{background:#f0f2f3;padding:10px 12px;margin-bottom:10px}.sidebar-box h3{font-size:8pt;margin:0 0 5px;text-transform:uppercase;letter-spacing:.09em}.sidebar-box p,.sidebar-box li{font-size:7.3pt;line-height:1.42}.sidebar-box ul{margin:0;padding-left:14px}.page-footer{position:absolute;left:.5in;right:.5in;bottom:.2in;border-top:1px solid #c8cdd1;padding-top:5px;display:flex;justify-content:space-between;font-size:6.4pt;color:#68737c}.resume-page2-header{display:flex;justify-content:space-between;align-items:center;border-bottom:4px solid var(--dvp-red);padding-bottom:8px;margin-bottom:12px}.resume-page2-header strong{font-family:"Noto Sans Display";font-size:13pt}.resume-page2-header span{font-size:6.7pt;color:#52606b;text-align:right}.letter-body{font-size:9.25pt;line-height:1.56}.letter-body p{margin:0 0 11px}.letter-meta{font-size:8pt;line-height:1.5;margin-bottom:18px}.signature{margin-top:14px;font-weight:800}.report-header{display:grid;grid-template-columns:1fr 1.65in;gap:.2in;align-items:center;margin-bottom:.2in;padding-bottom:.15in;border-bottom:5px solid var(--dvp-red)}.report-header .doc-logo-box{padding:8px 11px}.report-page h1{font-family:"Noto Sans Display";font-size:24pt;line-height:.98;margin:4px 0 8px}.report-page h2{font-family:"Noto Sans Display";font-size:13pt;margin:0 0 8px}.report-page h3{font-size:9pt;margin:0 0 5px}.report-page p,.report-page li{font-size:7.9pt;line-height:1.44}.report-page ul{margin:4px 0 0;padding-left:15px}.report-callout{background:var(--asphalt-950);color:#fff;padding:15px 17px;border-left:7px solid var(--dvp-blue);margin:11px 0}.report-callout strong{font-family:"Noto Sans Display";font-size:13pt}.report-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.report-card{border:1px solid #cfd4d8;padding:10px 11px;break-inside:avoid}.report-card.accent{border-top:5px solid var(--dvp-red)}.mini-table{width:100%;border-collapse:collapse;font-size:7.4pt}.mini-table th,.mini-table td{border:1px solid #cbd1d5;padding:5px 6px;vertical-align:top}.mini-table th{background:#1a1e23;color:#fff;text-align:left}.plan-lane{display:grid;grid-template-columns:.72in 1fr;gap:10px;padding:11px 0;border-bottom:1px solid #d4d8dc}.plan-day{font-family:"Noto Sans Display";font-size:13pt;color:var(--dvp-r